{
    "west_east_map": 20,
    "north_south_map": 20,
    "patience": 5,
    "delta": 1e-6,
    "seed": 2019,
    "data_type": "chicago",

    "all_data_filename": "data/chicago/all_data.pkl",
    "mask_filename": "data/chicago/risk_mask.pkl",
    "road_adj_filename": "data/chicago/road_adj.pkl",
    "risk_adj_filename": "data/chicago/risk_adj.pkl",
    "poi_adj_filename": "",
    "grid_node_filename": "data/chicago/grid_node_map.pkl",

    "recent_prior": 6,
    "week_prior": 4,
    "one_day_period": 24,
    "days_of_week": 7,
    "pre_len": 1,

    "train_rate": 0.6,
    "valid_rate": 0.2,
    "training_epoch": 200,
    "optimizer": "adam",
    "weight_decay": 0.0,

    "batch_size": 32,
    "learning_rate": 0.00001,
    "num_of_gru_layers": 2,
    "gru_hidden_size": 256,
    "gcn_num_filter": 128,
    "model_type": "dshgnn",
    "use_adaptive_feature_roles": false,
    "graph_feature_mode": "all",
    "use_prior_outputs": false,
    "use_weather": false,
    "use_weather_subgraph": false,
    "use_weather_as_relation": false,
    "use_weather_rank_head": false,
    "weather_top_k": 12,
    "weather_history_len": 24,
    "use_poi_in_grid": false,
    "use_grid_branch": false,
    "use_graph_gru": false,
    "propagation_backbone": "gt",
    "exclude_risk_in_functional_adj": false,
    "use_conditional_local_gate": false,
    "use_semantic_poi_adj": false,
    "monitor_metric": "val_rmse",
    "ranking_loss_weight": 0.0,
    "ranking_margin": 0.01,
    "ranking_max_negatives": 64,
    "high_frequency_loss_weight": 0.0,
    "high_frequency_hours": [6, 7, 8, 15, 16, 17, 18],
    "print_baseline_comparison": false,
    "save_predictions": true,
    "prediction_output_dir": "outputs/predictions",
    "save_role_summaries": false,
    "role_summary_output_dir": "outputs/role_summaries",
    "test_mode": false
}
